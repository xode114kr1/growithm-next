// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProblemPlatform {
  BAEKJOON    @map("baekjoon")
  PROGRAMMERS @map("programmers")
}

enum WebhookDeliveryStatus {
  RECEIVED     @map("received")
  IGNORED      @map("ignored")
  PROCESSED    @map("processed")
  NO_README    @map("no_readme")
  PARSE_FAILED @map("parse_failed")
  FETCH_FAILED @map("fetch_failed")
  FAILED       @map("failed")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  accounts                 Account[]
  sessions                 Session[]
  githubRepositoryWebhooks GitHubRepositoryWebhook[]
  problemSubmissions       ProblemSubmission[]
  ownedStudies             Study[]                   @relation("StudyOwner")
  studyMemberships         StudyMember[]
  studyProblemShares       StudyProblemShare[]

  @@map("users")
}

model Study {
  id          String   @id @default(cuid())
  ownerId     String   @map("owner_id")
  title       String
  description String?  @db.Text
  score       Float    @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner         User                @relation("StudyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members       StudyMember[]
  problemShares StudyProblemShare[]

  @@index([ownerId])
  @@map("studies")
}

model StudyMember {
  id        String   @id @default(cuid())
  studyId   String   @map("study_id")
  userId    String   @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  study Study @relation(fields: [studyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([studyId, userId])
  @@index([userId])
  @@map("study_members")
}

model StudyProblemShare {
  id                  String   @id @default(cuid())
  studyId             String   @map("study_id")
  userId              String   @map("user_id")
  problemSubmissionId String   @map("problem_submission_id")
  score               Float    @default(0)
  sharedAt            DateTime @default(now()) @map("shared_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  study             Study             @relation(fields: [studyId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemSubmission ProblemSubmission @relation(fields: [problemSubmissionId], references: [id], onDelete: Cascade)

  @@unique([studyId, problemSubmissionId])
  @@index([userId])
  @@index([problemSubmissionId])
  @@map("study_problem_shares")
}

model GitHubRepositoryWebhook {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  repositoryFullName String   @unique @map("repository_full_name")
  hookId             Int?     @map("hook_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("github_repository_webhooks")
}

model WebhookDelivery {
  id                 String                @id @default(cuid())
  deliveryId         String                @unique @map("delivery_id")
  event              String
  repositoryFullName String?               @map("repository_full_name")
  payload            Json
  status             WebhookDeliveryStatus @default(RECEIVED)
  errorMessage       String?               @map("error_message") @db.Text
  receivedAt         DateTime              @default(now()) @map("received_at")
  processedAt        DateTime?             @map("processed_at")

  problemSubmissions ProblemSubmission[]

  @@index([event])
  @@index([repositoryFullName])
  @@index([status])
  @@map("webhook_deliveries")
}

model ProblemSubmission {
  id                 String          @id @default(cuid())
  userId             String?         @map("user_id")
  webhookDeliveryId  String?         @map("webhook_delivery_id")
  repositoryFullName String          @map("repository_full_name")
  commitSha          String          @map("commit_sha")
  readmePath         String          @map("readme_path")
  code               String?         @db.Text
  memo               String?         @db.Text
  platform           ProblemPlatform
  problemId          String          @map("problem_id")
  title              String
  tier               String?
  link               String?
  memory             String?
  time               String?
  categories         Json?
  accuracy           Float?
  score              Float?
  scoreMax           Float?          @map("score_max")
  submittedAtText    String?         @map("submitted_at_text")
  description        String?         @db.Text
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  user            User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  webhookDelivery WebhookDelivery?    @relation(fields: [webhookDeliveryId], references: [id], onDelete: SetNull)
  studyShares     StudyProblemShare[]

  @@unique([repositoryFullName, commitSha, readmePath])
  @@index([userId])
  @@index([webhookDeliveryId])
  @@index([platform, problemId])
  @@map("problem_submissions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
